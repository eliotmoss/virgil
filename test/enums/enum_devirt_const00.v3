//@execute 0=10; 1=20; 2=99
// Constant enum receiver should devirt to the case's per-case override at
// compile time, even when accessed through an E-typed local.
enum E {
	A { def m() -> int { return 10; } },
	B { def m() -> int { return 20; } },
	C;
	def m() -> int { return 99; }
}
def main(arg: int) -> int {
	var a: E = E.A;
	var b: E = E.B;
	var c: E = E.C;
	match (arg) {
		0 => return a.m();
		1 => return b.m();
		2 => return c.m();
	}
	return -1;
}
